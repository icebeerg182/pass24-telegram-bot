# Telegram
TELEGRAM_BOT_TOKEN=

# Кто может пользоваться ботом (через запятую). Пусто = открыт всем, если нет админов.
TELEGRAM_ALLOWED_USER_IDS=

# Администраторы: /allow /deny /users (свой Telegram ID обязательно)
TELEGRAM_ADMIN_USER_IDS=

# PASS24 (мобильное API жителя)
PASS24_PHONE=+79XXXXXXXXX
PASS24_PASSWORD=

# Подстрока в названии адреса, если несколько объектов (пусто = первый адрес)
PASS24_ADDRESS_KEYWORD=

# Срок разового пропуска в часах
PASS24_PASS_HOURS=24

# Тип ТС по умолчанию
PASS24_VEHICLE_TYPE_KEYWORD=легков
PASS24_VEHICLE_TYPE_ID=
